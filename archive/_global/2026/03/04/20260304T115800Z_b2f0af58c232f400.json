      {
        "source": "ubuntu_security",
        "id": "https://ubuntu.com/security/notices/USN-5376-6",
        "url": "https://ubuntu.com/security/notices/USN-5376-6",
        "published_at": "2026-03-02T16:15:22Z",
        "updated_at": "2026-03-02T16:15:22Z",
        "headline": "USN-5376-6: Git regression",
        "content": {
          "excerpt_text": "USN-5376-4 fixed a regression in Git. This update provides the corresponding update for Ubuntu 18.04 LTS. We apologize for the inconvenience. Original advisory details: 俞晨东 discovered that Git incorrectly handled certain repository paths in platforms with multiple users support. An attacker could possibly use this issue to run arbitrary commands.",
          "lang": "en"
        },
        "provenance": {
          "fetched_at": "2026-03-04T11:57:04Z",
          "evidence_urls": [
            "https://ubuntu.com/security/notices/USN-5376-6"
          ],
          "content_hash": "sha256:30ca87f3bcc9367ec5461cc4afde2b119239c6750a8173ee9c4dd12ca66df6b4"
        },
        "source_payload": {
          "html": "USN-5376-4 fixed a regression in Git. This update provides the\ncorresponding update for Ubuntu 18.04 LTS.\n\nWe apologize for the inconvenience.\n\nOriginal advisory details:\n\n 俞晨东 discovered that Git incorrectly handled certain repository paths\n in platforms with multiple users support. An attacker could possibly use\n this issue to run arbitrary commands.",
