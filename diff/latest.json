        "updated_at": "2026-03-02T16:15:22Z",
        "headline": "USN-5376-6: Git regression",
        "content": {
          "excerpt_text": "USN-5376-4 fixed a regression in Git. This update provides the corresponding update for Ubuntu 18.04 LTS. We apologize for the inconvenience. Original advisory details: 俞晨东 discovered that Git incorrectly handled certain repository paths in platforms with multiple users support. An attacker could possibly use this issue to run arbitrary commands.",
          "lang": "en"
        },
        "provenance": {
          "fetched_at": "2026-03-04T11:57:04Z",
          "evidence_urls": [
            "https://ubuntu.com/security/notices/USN-5376-6"
